# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./codechat.db

# ─── Groq Cloud LLM ────────────────────────────────────────────────────────────
# CodeChat relies on Groq for instant, local-free AI responses.
# Get your API key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

LLM_MAX_TOKENS=1200
RAG_TOP_K=3
EMBEDDING_LOCAL_ONLY=true

# ─── Optional provider overrides ─────────────────────────────────────────────
# Only needed if manually changing LLM_PROVIDER in rag_pipeline.py
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
