# ═════════════════════════════════════════════════════════════════════════════
# CodeChat Backend Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ─── 🔐 JWT Authentication ────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET_KEY before deploying to production!
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── 🗄️  Database ──────────────────────────────────────────────────────────────
# SQLite is used by default (no setup needed). 
# For PostgreSQL, use: postgresql://username:password@localhost/dbname
DATABASE_URL=sqlite:///./codechat.db

# ─── 🤖 Groq Cloud LLM (REQUIRED) ─────────────────────────────────────────────
# CodeChat uses Groq for fast, free AI responses.
# 
# ⚠️  GET YOUR KEY: Visit https://console.groq.com
#   1. Sign up (free)
#   2. Create an API key
#   3. Copy and paste it below (it starts with "gsk_")
#
# If you don't have this, the app WILL NOT WORK!
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─── 🎯 LLM Settings ──────────────────────────────────────────────────────────
LLM_MAX_TOKENS=1200
RAG_TOP_K=3
EMBEDDING_LOCAL_ONLY=true

# ─── Optional: Alternative LLM Providers ──────────────────────────────────────
# Only needed if you want to use OpenAI or Anthropic instead of Groq
# Uncomment and add your API key if needed
# OPENAI_API_KEY=sk_...
# ANTHROPIC_API_KEY=sk-ant-...
