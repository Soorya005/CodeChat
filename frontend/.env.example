# ═════════════════════════════════════════════════════════════════════════════
# CodeChat Frontend Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ─── 🔗 Backend Connection ────────────────────────────────────────────────────
# This must match where your backend is running.
# Default: http://localhost:8000 (for local development)
# If backend runs on different port, update this
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── ⏱️  Query Timeout ─────────────────────────────────────────────────────────
# How long to wait for API responses (in milliseconds)
# Default: 5 minutes = 300000ms
NEXT_PUBLIC_QUERY_TIMEOUT_MS=300000
